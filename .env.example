# Undermine Exchange API key (required)
UNDERMINE_API_KEY=your_key_here

# Telegram bot (required)
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Realm to scan for deals 
REALM=your_relm_name_here
REGION=eu

# Only alert when a realm price is ≤ this % of the regional median (default: 5.0)
PRICE_PERCENT_THRESHOLD=5.0

# Blizzard API credentials (optional — enables item name resolution in alerts)
# BLIZZARD_CLIENT_ID=your_client_id
# BLIZZARD_CLIENT_SECRET=your_client_secret

# State file path (defaults to state.json in current dir)
# STATE_FILE_PATH=/home/spike/underbot/state.json
